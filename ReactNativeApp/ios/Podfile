# Resolve react_native_pods.rb via node so it works with yarn/npm/bun hoisting
require Pod::Executable.execute_command('node', ['--print',
  "require('path').resolve(require.resolve('react-native/package.json'), '..', 'scripts', 'react_native_pods.rb')",
]).strip

# New Architecture is the default in RN 0.84, but being explicit is good practice.
ENV['RCT_NEW_ARCH_ENABLED'] = '1'
# RN 0.84 defaults to prebuilt rncore xcframeworks. Disable to avoid duplicate
# ObjC class warnings between React.framework and the Xcode debug dylib.
ENV['RCT_USE_PREBUILT_RNCORE'] = '0'

# min_ios_version_supported is a helper from react_native_pods.rb (resolves to 15.1 for RN 0.76).
platform :ios, min_ios_version_supported

prepare_react_native_project!

target 'ReactNativePoC' do
  # Podfile is in ios/ — pass parent dir so autolinking finds package.json at the JS root.
  app_path = "#{Pod::Config.instance.installation_root.parent}"

  config = use_native_modules!

  # expo-modules-core: powers the Swift Expo Module DSL (no C++ codegen required).
  # ExpoModulesJSI is a separate podspec in the same package (JSI bindings layer).
  # Managed explicitly — do NOT call use_expo_modules! which would inject a conflicting
  # ExpoModulesProvider.swift alongside our TescoNativeBridgePod version.
  pod 'ExpoModulesJSI', :path => '../node_modules/expo-modules-core'
  pod 'ExpoModulesCore', :path => '../node_modules/expo-modules-core', :modular_headers => true
  # Required by the tescornappbrownfield framework template (generated by expo prebuild).
  pod 'ExpoBrownfield', :path => '../node_modules/expo-brownfield/ios'
  pod 'EXManifests', :path => '../node_modules/expo-manifests/ios'

  # TescoNativeBridge is now a pure Swift Expo Module.
  # No codegen files, no install_modules_dependencies — just s.dependency 'ExpoModulesCore'.
  pod 'TescoNativeBridge', :path => './TescoNativeBridgePod'

  use_react_native!(
    :path => config[:reactNativePath],
    # Hermes is the default JS engine for RN 0.76 New Architecture.
    :hermes_enabled => true,
    # package.json lives one level up from ios/ (the JS project root).
    :app_path => app_path
  )

  post_install do |installer|
    # Required by RN New Architecture — sets compiler flags, linker settings, etc.
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )

    # The Expo pod declares `s.dependency 'ExpoModulesCore'` only when use_expo_modules! is
    # defined. Since we manage ExpoModulesCore explicitly without calling use_expo_modules!,
    # CocoaPods does not add ExpoModulesCore or ExpoModulesJSI to Expo's xcconfig.
    # We need to:
    #   1. Add explicit target dependencies so ExpoModulesCore/JSI compile BEFORE Expo
    #      (ExpoModulesCore-Swift.h is generated at compile time and required by Expo's .mm files)
    #   2. Inject ObjC/C header search paths and module maps
    #   3. Inject SWIFT_INCLUDE_PATHS so Swift finds ExpoModulesCore's built Swift module
    expo_target      = installer.pods_project.targets.find { |t| t.name == 'Expo' }
    expo_core_target = installer.pods_project.targets.find { |t| t.name == 'ExpoModulesCore' }
    expo_jsi_target  = installer.pods_project.targets.find { |t| t.name == 'ExpoModulesJSI' }
    expo_target.add_dependency(expo_core_target) if expo_target && expo_core_target
    expo_target.add_dependency(expo_jsi_target)  if expo_target && expo_jsi_target

    expo_core_headers = '"${PODS_ROOT}/Headers/Public/ExpoModulesCore"'
    expo_core_modulemap = '"${PODS_ROOT}/Headers/Public/ExpoModulesCore/ExpoModulesCore.modulemap"'
    expo_jsi_headers = '"${PODS_ROOT}/Headers/Public/ExpoModulesJSI"'
    expo_jsi_modulemap = '"${PODS_ROOT}/Headers/Public/ExpoModulesJSI/ExpoModulesJSI.modulemap"'
    expo_core_swift_module = '"${PODS_CONFIGURATION_BUILD_DIR}/ExpoModulesCore"'
    installer.pods_project.targets.each do |target|
      next unless target.name == 'Expo'
      target.build_configurations.each do |bc|
        bc.build_settings['HEADER_SEARCH_PATHS'] =
          "$(inherited) #{expo_core_headers} #{expo_jsi_headers}"
        bc.build_settings['OTHER_CFLAGS'] =
          "$(inherited) -fmodule-map-file=#{expo_core_modulemap} -fmodule-map-file=#{expo_jsi_modulemap}"
        bc.build_settings['OTHER_SWIFT_FLAGS'] =
          "$(inherited) -Xcc -fmodule-map-file=#{expo_core_modulemap} -Xcc -fmodule-map-file=#{expo_jsi_modulemap}"
        bc.build_settings['SWIFT_INCLUDE_PATHS'] =
          "$(inherited) #{expo_core_swift_module}"
      end
    end
  end

  target 'tescornappbrownfield' do
    inherit! :complete
  end
end

# ─── SPM Note ───────────────────────────────────────────────────────────────
# React Native does not yet distribute via Swift Package Manager.
# Blockers as of RN 0.76:
#   • Codegen (TurboModule spec generation) is driven by CocoaPods pod hooks
#   • react_native_post_install configures Hermes build phases SPM can't replicate
#   • No Package.swift in the react-native npm package
# Revisit when RN 0.80+ ships full SPM support (CocoaPods trunk read-only: Dec 2026).
# ────────────────────────────────────────────────────────────────────────────
